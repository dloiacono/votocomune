# Comunali Backend - Environment Variables

# Database Configuration
DB_USER=comunali
DB_PASSWORD=comunali_secure_password
DB_URL=jdbc:postgresql://localhost:5432/comunali

# CORS Configuration (production)
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# JWT Configuration
# Questi sono tipicamente fissi e configurati nel application.properties
# JWT_ISSUER=https://comunali.app
# JWT_EXPIRATION_SECONDS=28800

# Application Profile (dev o prod)
QUARKUS_PROFILE=dev

# Logging
# QUARKUS_LOG_LEVEL=DEBUG
